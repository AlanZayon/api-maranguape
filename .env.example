# Database
MONGO_CONNECTING_FUNCIONARIOS=mongodb://localhost:27017/funcionarios
MONGO_CONNECTING_USUARIOS=mongodb://localhost:27017/funcionarios

# Authentication
JWT_SECRET=dev_jwt_secret_change_me
JWT_EXPIRES_IN=24h

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# Redis
REDIS_URL=redis://localhost:6379

# BullMQ bulk worker (embedded in API process by default)
# Set to false and run `npm run worker:bulk` separately in production if preferred
BULK_WORKER_EMBEDDED=true

# Nest migration
# all = Nest owns every domain (default)
NEST_MIGRATED=all

# Server
PORT=3000
NODE_ENV=development

# Multi-tenant
# Local: deixe vazio (CORS libera *.localhost)
# Produção: BASE_DOMAIN=seudominio.com
BASE_DOMAIN=
# Origins extras separados por vírgula
CORS_ORIGINS=http://master.localhost:5173,http://maranguape.localhost:5173

# Branding / custom CSS policy (fonte da verdade; front lê via GET /api/tenants/branding-policy)
TENANT_CUSTOM_CSS_ENABLED=true
TENANT_CUSTOM_CSS_MAX_LENGTH=20000
# Campos de branding que admin/superadmin podem gravar (CSV)
TENANT_BRANDING_EDITABLE_FIELDS=logoUrl,faviconUrl,displayName,primaryColor,secondaryColor,primaryContrast,headerBg,headerText,sidebarBg,sidebarText,surfaceBg,pageBg,textColor,mutedColor,borderColor,fontFamily,fontUrl,themeMode,customCss
# Prefixos de seletor permitidos no customCss
TENANT_CUSTOM_CSS_ALLOWED_SELECTORS=.login-page,.login-card,.sidebar,.app-header,.app-shell,.btn-brand,.dashboard-page,.dashboard-stat,.relatorio-preview,.relatorio-document
# Hosts permitidos para fontUrl
TENANT_FONT_URL_HOSTS=fonts.googleapis.com,fonts.gstatic.com
# Teto de upload logo/favicon (bytes)
TENANT_BRANDING_ASSET_MAX_BYTES=2097152
